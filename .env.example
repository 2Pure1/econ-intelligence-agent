# Econ Intelligence Agent - Configuration Template

# API Keys
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
OPENAI_API_KEY=your_openai_key_here
